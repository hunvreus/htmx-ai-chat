{% extends "layouts/base.html" %}

{% block content %}
  {% from 'macros/sidebar.html' import sidebar %}
  {{ sidebar(
    id="sidebar-123456",
    label="Sidebar navigation",
    open=True,
    side="left",
    menu=[
      {"label": "Group", "type": "group", "items": [
        {"label": "Home", "url": "/"},
        {"label": "About", "url": "/about"},
        {"label": "Contact", "url": "/contact"}
      ]}
    ],
    main_attrs={"class": "max-w-sm"},
    header_attrs={"class": "max-w-sm"},
    content_attrs={"class": "max-w-sm"},
    footer_attrs={"class": "max-w-sm"}
  ) }}
  <main class="flex flex-col h-screen pb-6">
    <header class="flex items-center gap-2">
      <button
        type="button"
        onclick="window.dispatchEvent(new CustomEvent('sidebar:toggle'))"
        aria-label="Toggle sidebar"
        data-tooltip="Toggle sidebar"
        data-side="bottom"
        data-align="start"
        class="btn-sm-icon-ghost mr-auto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-panel-left-icon lucide-panel-left"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
      </button>

      <button
        type="button"
        class="btn-sm-ghost"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-share-icon lucide-share"><path d="M12 2v13"/><path d="m16 6-4-4-4 4"/><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/></svg>
        Share
      </button>
      <button
        type="button"
        class="btn-sm-icon-ghost"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ellipsis-icon lucide-ellipsis"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
      </button>
    </header>

    <div id="chat" class="flex flex-col flex-1 overflow-y-auto scrollbar">
      <div class="flex flex-col gap-6 flex-1 max-w-3xl mx-auto w-full px-4 py-6">
        {% for message in messages %}
          {% include 'partials/_message.html' %}
        {% endfor %}
      </div>
    </div>
      
    <form
      class="border rounded-xl p-4 flex flex-col gap-4 max-w-3xl mx-auto w-full"
      hx-post="/message"
      hx-target="#chat"
      hx-swap="beforeend"
      enctype="multipart/form-data"
      hx-indicator="#chat .loading"
      x-data="{
        message: ''
      }"
    >
      <span x-text="message"></span>
      <textarea
        class="appearance-none w-full field-sizing-content resize-none hover:outline-none focus:outline-none"
        name="message"
        placeholder="Ask anything..."
        required
        x-model="message"
      ></textarea>
      <div class="flex items-center gap-2">
        <label class="btn-icon-outline">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-paperclip-icon lucide-paperclip"><path d="m16 6-8.414 8.586a2 2 0 0 0 2.829 2.829l8.414-8.586a4 4 0 1 0-5.657-5.657l-8.379 8.551a6 6 0 1 0 8.485 8.485l8.379-8.551"/></svg>
          <input type="file" name="file" accept="image/*" class="hidden">
        </label>

        {% from 'macros/select.html' import select %}
        {{ select(
          id="select-229684",
          selected="apple",
          items=[
            {"label": "ChatGPT 4o", "value": "chatgpt-4o"},
            {"label": "ChatGPT o3", "value": "chatgpt-o3"},
            {"label": "Grok 3", "value": "grok-3"}
          ],
          popover_attrs={"data-side": "top"}
        ) }}

        <button class="btn-icon ml-auto" type="submit" :disabled="!message">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-up-icon lucide-arrow-up"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
          <span class="sr-only">Send</span>
        </button>
      </div>
    </form>
  </main>
{% endblock %}